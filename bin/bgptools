#!/bin/bash
#
# bgptools - CLI tool to fetch BGP information from bgp.tools
# Usage: bgptools <ip|asn>
#

set -uo pipefail

VERSION="1.1.1"

# Colors
BOLD='\033[1m'
CYAN='\033[0;36m'
GRAY='\033[0;90m'
RESET='\033[0m'

usage() {
    echo "bgptools v$VERSION - Look up BGP information from bgp.tools"
    echo ""
    echo "Usage: bgptools <ip-address | AS-number>"
    echo ""
    echo "Examples:"
    echo "  bgptools 1.1.1.1"
    echo "  bgptools 2606:4700::1111"
    echo "  bgptools AS13335"
    echo "  bgptools 13335"
    echo ""
    echo "Options:"
    echo "  -h, --help       Show this help message"
    echo "  -v, --version    Show version"
    exit 1
}

print_field() {
    local label="$1"
    local value="$2"
    if [[ -n "$value" ]]; then
        printf "${CYAN}%-20s${RESET} %s\n" "$label:" "$value"
    fi
}

print_header() {
    echo ""
    echo -e "${BOLD}$1${RESET}"
    echo "────────────────────────────────────────"
}

query_whois() {
    whois -h bgp.tools " -v $1" 2>/dev/null
}

lookup() {
    local input="$1"
    local query="$input"

    # Normalize: strip AS prefix for display, keep for query
    local display="$input"
    if [[ "$input" =~ ^[Aa][Ss]([0-9]+)$ ]]; then
        query="as${BASH_REMATCH[1]}"
        display="AS${BASH_REMATCH[1]}"
    elif [[ "$input" =~ ^[0-9]+$ ]]; then
        query="as${input}"
        display="AS${input}"
    fi

    # Query whois
    local result
    result=$(query_whois "$query")

    if [[ -z "$result" ]] || echo "$result" | grep -qi "error\|not found"; then
        echo "Error: '$input' not found on bgp.tools"
        exit 1
    fi

    # Skip header line
    local data
    data=$(echo "$result" | tail -n +2)

    if [[ -z "$data" ]]; then
        echo "Error: No data returned for '$input'"
        exit 1
    fi

    # Parse the pipe-delimited response
    while IFS='|' read -r as_field ip_field prefix_field cc_field registry_field allocated_field name_field; do
        # Trim whitespace
        local asn ip prefix cc registry allocated name
        asn=$(echo "$as_field" | xargs)
        ip=$(echo "$ip_field" | xargs)
        prefix=$(echo "$prefix_field" | xargs)
        cc=$(echo "$cc_field" | xargs)
        registry=$(echo "$registry_field" | xargs)
        allocated=$(echo "$allocated_field" | xargs)
        name=$(echo "$name_field" | xargs)

        # Determine header
        if [[ -n "$ip" && -n "$prefix" ]]; then
            print_header "$display -> $prefix"
        elif [[ -n "$asn" ]]; then
            print_header "AS$asn - $name"
        fi
        echo ""

        [[ -n "$name" ]]      && print_field "Name" "$name"
        [[ -n "$asn" ]]       && print_field "ASN" "AS$asn"
        [[ -n "$ip" ]]        && print_field "IP" "$ip"
        [[ -n "$prefix" ]]    && print_field "BGP Prefix" "$prefix"
        [[ -n "$cc" ]]        && print_field "Country" "$cc"
        [[ -n "$registry" ]]  && print_field "Registry" "$registry"
        [[ -n "$allocated" && "$allocated" != "0001-01-01" ]] && print_field "Allocated" "$allocated"

    done <<< "$data"

    echo ""
    echo -e "${GRAY}Source: bgp.tools (whois)${RESET}"
    echo ""
}

# --- Main ---

if [[ $# -lt 1 ]]; then
    usage
fi

case "${1:-}" in
    -h|--help) usage ;;
    -v|--version) echo "bgptools v$VERSION"; exit 0 ;;
esac

input="$1"

if [[ "$input" =~ ^[Aa][Ss][0-9]+$ ]] || [[ "$input" =~ ^[0-9]+$ ]] || [[ "$input" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9] ]] || [[ "$input" =~ : ]]; then
    lookup "$input"
else
    echo "Error: '$input' doesn't look like an IP address or ASN number."
    echo ""
    usage
fi
